# ============================================================
# REP WhatsApp Bot — Variables de entorno
# ============================================================
# Copiá este archivo a .env y configurá los valores reales.
# En Render/Railway, cargá estas variables desde el dashboard.
# ============================================================

# === Secret compartido con el endpoint de Vercel ===
# Debe coincidir EXACTAMENTE con WHATSAPP_BOT_SECRET configurado
# en Vercel. Si no coincide, el endpoint devuelve 401.
WHATSAPP_BOT_SECRET=f07ec8dbf2f2c54971c2595babdc70b50231b74dee83e7f79cc978023507f0c6

# === URL del endpoint de IA en Vercel ===
# Endpoint que recibe el mensaje, lo procesa con Groq (llama-3.3-70b-versatile)
# y devuelve { reply: string } con la respuesta para el paciente.
VERCEL_API_URL=https://www.redescuchapsicologica.com/api/whatsapp/process

# === Puerto del servidor HTTP (Render/Railway lo inyectan automáticamente) ===
# En local, usar 3000. En Render, NO definir esta variable (la inyecta la plataforma).
# PORT=3000

# === Horario de Guardia Nocturna (hora Argentina, formato 24hs) ===
# El bot SOLO responde mensajes entre GUARD_START_HOUR y GUARD_END_HOUR.
# Fuera de ese rango, los mensajes se ignoran (responde un humano).
# Default: 20 (8 PM) a 8 (8 AM).
GUARD_START_HOUR=20
GUARD_END_HOUR=8

# === Rate limiting (anti-spam) ===
# Máximo 1 mensaje por usuario cada N segundos. Evita que un usuario
# inunde el bot y consuma cuota de IA en vano.
# Default: 30 segundos.
RATE_LIMIT_SECONDS=30
